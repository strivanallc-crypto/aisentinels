# Copy this to .env for local development

# Database (local dev: use postgres; production: leave empty and set DB_SECRET_ARN)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aisentinels_db

# AWS (production only — set from CDK outputs)
DB_SECRET_ARN=
AWS_REGION=us-east-1

# Cognito (from CDK outputs: CognitoUserPoolId and CognitoClientId)
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# S3 (from CDK outputs: DocumentBucketName)
S3_BUCKET_NAME=

# AI (get from Google AI Studio: https://makersuite.google.com/)
GEMINI_API_KEY=

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
